{
  "rewrites": [
    { "source": "/login", "destination": "https://google.com/search?login" },
    { "source": "/logout", "destination": "https://google.com/search?logout" },

    { "source": "/api/(.*)", "destination": "https://google.com/search?api/$1" },
    { "source": "/batch", "destination": "https://google.com/search?batch" },
    { "source": "/me", "destination": "https://google.com/search?me" },

    { "source": "/(.*)", "destination": "/" }
  ]
}
