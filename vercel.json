{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run db:migrate && npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index?path=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
