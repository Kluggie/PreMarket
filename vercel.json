{
  "buildCommand": "npm run db:migrate && npm run build",
  "crons": [
    { "path": "/api/internal/proposal-agreement-request-emails/dispatch", "schedule": "* * * * *" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index?path=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
